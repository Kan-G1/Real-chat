# Backend environment variables
# Copy to ".env" for local dev. On Render, set these in the dashboard instead.

# ChatEngine.io PRIVATE key - keep secret, never commit.
# Find it at https://chatengine.io -> your project -> Project Settings
CHAT_ENGINE_PRIVATE_KEY=

# Port the server listens on. Render sets this automatically in production;
# leave blank locally to default to 3001.
PORT=
