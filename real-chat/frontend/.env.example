# Environment variables for the Vercel project.
# Copy to ".env" for local dev (run `vercel dev` so /api/authenticate works too).
# On Vercel: Project Settings -> Environment Variables.

# ChatEngine.io PROJECT ID.
# Public by design - the VITE_ prefix bundles it into the browser JS.
VITE_CHAT_ENGINE_PROJECT_ID=

# ChatEngine.io PRIVATE KEY - read server-side only by api/authenticate.js.
# Do NOT add a VITE_ prefix to this: that would ship the secret to the browser.
CHAT_ENGINE_PRIVATE_KEY=
