# Frontend environment variables (Vite)
# Copy to ".env" for local dev. On Vercel, set these in Project Settings -> Environment Variables.
# NOTE: anything prefixed VITE_ is bundled into the public JS - never put secrets here.

# Base URL of the deployed backend (no trailing slash).
# Local dev: http://localhost:3001
VITE_API_URL=

# ChatEngine.io PROJECT ID (public by design - safe to expose client-side).
# Find it at https://chatengine.io -> your project
VITE_CHAT_ENGINE_PROJECT_ID=
